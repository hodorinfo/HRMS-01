# Horilla HRMS Microservices - Environment Configuration

# PostgreSQL
POSTGRES_USER=horilla
POSTGRES_PASSWORD=horilla
POSTGRES_DB=horilla

# Redis
REDIS_URL=redis://redis:6379/0

# JWT (shared across all services)
JWT_SECRET_KEY=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Service URLs (internal Docker network)
IDENTITY_SERVICE_URL=http://identity-service:8000
CORE_SERVICE_URL=http://core-service:8000
ATTENDANCE_SERVICE_URL=http://attendance-service:8000
PAYROLL_SERVICE_URL=http://payroll-service:8000
PERMISSION_SERVICE_URL=http://permission-service:8000
TALENT_SERVICE_URL=http://talent-service:8000
PLATFORM_SERVICE_URL=http://platform-service:8000

# Django UI BFF
DJANGO_SECRET_KEY=change-me-django-secret-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*

# Database URLs per service
IDENTITY_DATABASE_URL=postgresql+asyncpg://horilla:horilla@postgres:5432/horilla_identity
CORE_DATABASE_URL=postgresql+asyncpg://horilla:horilla@postgres:5432/horilla_core
ATTENDANCE_DATABASE_URL=postgresql+asyncpg://horilla:horilla@postgres:5432/horilla_attendance
PAYROLL_DATABASE_URL=postgresql+asyncpg://horilla:horilla@postgres:5432/horilla_payroll
PERMISSION_DATABASE_URL=postgresql+asyncpg://horilla:horilla@postgres:5432/horilla_permission
TALENT_DATABASE_URL=postgresql+asyncpg://horilla:horilla@postgres:5432/horilla_talent
PLATFORM_DATABASE_URL=postgresql+asyncpg://horilla:horilla@postgres:5432/horilla_platform

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
